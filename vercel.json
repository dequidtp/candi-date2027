{
  "version": 2,
  "builds": [
    { "src": "api/*.js",      "use": "@vercel/node" },
    { "src": "*.html",        "use": "@vercel/static" },
    { "src": "*.css",         "use": "@vercel/static" },
    { "src": "*.js",          "use": "@vercel/static" },
    { "src": "*.txt",         "use": "@vercel/static" },
    { "src": "assets/**/*",   "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "all" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/game",            "dest": "/api/game.js"            },
    { "src": "/api/stats",           "dest": "/api/stats.js"           },
    { "src": "/api/salon/create",    "dest": "/api/salon-create.js"    },
    { "src": "/api/salon/join",      "dest": "/api/salon-join.js"      },
    { "src": "/api/salon/complete",  "dest": "/api/salon-complete.js"  },
    { "src": "/api/salon/info",      "dest": "/api/salon-info.js"      },
    { "src": "/(.*)",                "dest": "/$1"                     }
  ]
}
